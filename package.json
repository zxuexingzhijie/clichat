{
  "name": "chronicle-cli",
  "version": "1.4.0",
  "description": "AI-driven CLI interactive novel game",
  "type": "module",
  "bin": {
    "chronicle": "dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "world-data/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/cli.ts --outfile dist/cli.js --target bun --minify --external react-devtools-core",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "engines": {
    "bun": ">=1.3.12"
  },
  "keywords": [
    "cli",
    "game",
    "interactive-fiction",
    "ai",
    "rpg",
    "terminal",
    "text-adventure"
  ],
  "license": "MIT",
  "author": "Makoto",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zxuexingzhijie/clichat.git"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/figlet": "^1.7.0",
    "@types/react": "^19.2.14",
    "bun-types": "^1.3.12"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@ai-sdk/alibaba": "0.0.6",
    "@ai-sdk/anthropic": "1.2.12",
    "@ai-sdk/deepseek": "1.0.37",
    "@ai-sdk/google": "1.2.22",
    "@ai-sdk/openai": "1.3.24",
    "@ai-sdk/openai-compatible": "1.0.36",
    "@inkjs/ui": "^2.0.0",
    "ai": "^5.0.179",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "env-paths": "^4.0.0",
    "figlet": "^1.11.0",
    "fullscreen-ink": "^0.1.0",
    "gradient-string": "^3.0.0",
    "immer": "^11.1.4",
    "ink": "^7.0.1",
    "mitt": "^3.0.1",
    "nanoid": "^5.1.9",
    "react": "^19.2.5",
    "string-width": "^8.2.0",
    "strip-ansi": "^7.2.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
